import { describe, it, expect, beforeEach } from 'vitest';
import { buildInitialState } from '../state/state-builder';
import { basicConfig } from './fixtures';
import { getPlayer, getWizard } from '../state/selectors';
import { applyEvent } from '../events/apply-event';
import type { GameState, WizardReleasedEvent } from '../../../shared/src/types';

describe('Unseal Mechanism (TC-UNSEAL-001)', () => {
  let state: GameState;
  const P1 = 'P1';

  beforeEach(() => {
    state = buildInitialState({ ...basicConfig, playerCount: 1 }, 'test-seed');
  });

  it('should correctly release a wizard when WIZARD_RELEASED event is applied', () => {
    // 1. Setup: Imprison a wizard
    const wizardToImprison = getWizard(state, getPlayer(state, P1).wizardIds[0]);
    const imprisonSpaceIndex = 5;
    wizardToImprison.position = { mode: 'IMPRISONED', spaceIndex: imprisonSpaceIndex };

    expect(getWizard(state, wizardToImprison.id).position.mode).toBe('IMPRISONED');

    // 2. Create the event to release the wizard to the top of a tower
    const releaseEvent: WizardReleasedEvent = {
      type: 'WIZARD_RELEASED',
      payload: {
        wizardId: wizardToImprison.id,
        source: 'SPELL', // or 'ACTION'
        from: wizardToImprison.position,
        to: { mode: 'ON_TOWER_TOP', spaceIndex: imprisonSpaceIndex, topTowerId: 'T1' },
      },
    };

    // 3. Apply the event
    const newState = applyEvent(state, releaseEvent);

    // 4. Assert: The wizard is now on top of the tower
    const releasedWizard = getWizard(newState, wizardToImprison.id);
    expect(releasedWizard.position.mode).toBe('ON_TOWER_TOP');
    expect(releasedWizard.position.spaceIndex).toBe(imprisonSpaceIndex);
  });
});